# SplitVault local environment.
# Copy to .env.local. Keep this file committed, but never commit .env.local.

# ── Private Keys ──────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
RELAYER_ADDRESS=
RELAYER_PRIVATE_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_DB_URL=
SUPABASE_SERVICE_KEY=

# ── Celo Sepolia DIRECT MVP ──────────────────────────────────────────────────
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
VITE_CELO_CHAIN_ID=11142220
VITE_CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Deployed test contracts on Celo Sepolia.
CUSD_ADDRESS_CELO_SEPOLIA=0xBFa30e9f862776349b881875027990223bf122bD
VITE_CUSD_ADDRESS=0xBFa30e9f862776349b881875027990223bf122bD
FACTORY_ADDRESS=0x5aAd01D69AB5cAe93c7Cc3D88EDE1A2dEe7E7c28
VITE_VAULT_FACTORY_ADDRESS=0x5aAd01D69AB5cAe93c7Cc3D88EDE1A2dEe7E7c28

# Local services.
PORT=3000
VITE_RELAYER_BASE_URL=https://splitvault-relayer-production.up.railway.app
ENABLE_BRIDGE_CARD=false
VITE_ENABLE_BRIDGE_CARD=false

