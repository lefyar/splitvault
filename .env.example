# SplitVault local environment.
# Copy to .env.local. Keep this file committed, but never commit .env.local.

# ── Private Keys ──────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
RELAYER_ADDRESS=
RELAYER_PRIVATE_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_DB_URL=
SUPABASE_SERVICE_KEY=
MERCHANT_ADMIN_TOKEN=

# ── Celo Mainnet DIRECT launch ───────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org
VITE_CELO_CHAIN_ID=42220
VITE_CELO_RPC_URL=https://forno.celo.org

CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
VITE_CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
FACTORY_ADDRESS=0x82A9D7C665133377f307b2214B0195E55556898b
VITE_VAULT_FACTORY_ADDRESS=0x82A9D7C665133377f307b2214B0195E55556898b

# Local/hosted services.
PORT=3000
VITE_RELAYER_BASE_URL=https://splitvault-relayer-production.up.railway.app
RELAYER_BASE_URL=https://splitvault-relayer-production.up.railway.app
ENABLE_BRIDGE_CARD=false
VITE_ENABLE_BRIDGE_CARD=false
ENABLE_UPKEEP_CRON=false
UPKEEP_INTERVAL_MS=300000
ALLOW_MAINNET_UPKEEP=false

# Optional merchant admin seeding.
MERCHANT_SEED_ID=custom-direct-wallet
MERCHANT_SEED_CHAIN_ID=42220
MERCHANT_SEED_TOKEN_SYMBOL=cUSD
MERCHANT_SEED_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
MERCHANT_SEED_PAYOUT_ADDRESS=

# Optional vault metadata repair.
REPAIR_CHAIN_ID=42220
REPAIR_VAULT_ADDRESS=
REPAIR_SERVICE_NAME=

# ── Celo Sepolia values, only for testnet regression work ────────────────────
# CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
