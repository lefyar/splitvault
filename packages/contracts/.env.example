# ── Smart Contracts Environment Variables ──────────────────────────────────────

# ── RPC Endpoints ────────────────────────────────────────────────────────────────
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# ── Deployment Account ──────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=

# ── Celo Addresses ──────────────────────────────────────────────────────────────
# Celo Sepolia USDm/cUSD-compatible Mento Dollar: 0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b
# Mainnet cUSD: 0x765DE816845861e75A25fCA122bb6898B8B1282a
# Alfajores cUSD: 0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
CUSD_ADDRESS_CELO_SEPOLIA=0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
CUSD_ADDRESS_ALFAJORES=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1

# ── Automation (Gelato) ─────────────────────────────────────────────────────────
# Gelato keeper address (will be used to call executePayment & refundCycle)
# Get from Gelato dashboard or use their sample keeper address for testing
GELATO_KEEPER=

# ── Relayer Address ─────────────────────────────────────────────────────────────
# Relayer EOA that signs confirmPaymentAndReset() calls
# Should be a separate, hot wallet controlled by the relayer backend
RELAYER_ADDRESS=

# ── Block Explorers ─────────────────────────────────────────────────────────────
# For --verify flag on forge script
CELOSCAN_API_KEY=
